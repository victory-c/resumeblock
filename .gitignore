# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files — copy .env.example to .env and fill in values
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma generated client
/lib/generated/prisma

# application data — generated at runtime, not committed
/data/resumeblock.db
/data/resumeblock.db-journal
/data/output/
/data/uploads/
/prisma/data/*.db
/prisma/data/*.db-journal
# templates are committed so the app has a default template on first run
# if you want to exclude them too, uncomment the next line:
# /data/templates/
