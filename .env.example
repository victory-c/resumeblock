# Copy this file to .env and fill in values for your machine.
# Never commit .env — it contains machine-specific paths and secrets.

# SQLite database location (relative to project root)
DATABASE_URL="file:./data/resumeblock.db"

# Ollama local LLM settings
# Install Ollama: https://ollama.com
# After installing, run: ollama pull <model-name>
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2:latest"   # or llama3.1:8b, mistral, etc. — must be pulled first

# File storage directories (relative to project root, created automatically)
UPLOAD_DIR="./data/uploads"
TEMPLATES_DIR="./data/templates"
OUTPUT_DIR="./data/output"
